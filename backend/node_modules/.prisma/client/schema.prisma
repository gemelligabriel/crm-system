generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Patient {
  id         Int         @id @default(autoincrement())
  name       String
  birthDate  DateTime
  phone      String?
  email      String?
  cpf        String?
  address    String?
  profession String?
  origin     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  events     Event[]
  evolutions Evolution[]
}

model Event {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId Int
}

model Evolution {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  startTime   String
  endTime     String
  description String
  createdAt   DateTime @default(now())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId   Int
}
